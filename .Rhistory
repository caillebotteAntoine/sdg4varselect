theme(legend.position = 'None') +
labs(y = '',x = '') +
xlim(0,10) + ylim(0,1) +
geom_segment(aes(x = 1,xend = 3, y = 0.25, yend = logistic(3)),
linewidth = 1, arrow = arrow(length = unit(0.03, "npc")) +
annotate('text', x = 1, y = .28, label = "known information", size = mysize) +
gg
