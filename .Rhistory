geom_segment(aes(x = 2.5,xend = 6, y = 0.72, yend = logistic(6, 0.8, 5, 0.6)),
linewidth = 1, arrow = arrow(length = unit(0.03, "npc"))) +
annotate('text', x = 2.5, y = .75, label = "Not yet observed", size = mysize)
gg
ggsave('images/logistic_pred.png', gg, width = 8.2 , height = 5.6)
getwd()
